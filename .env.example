# Скопируйте в .env.local (не коммить секреты).

# По умолчанию: POST /api/integrations/site/leads (тот же origin; nginx → tipa.taska.uz).
# VITE_LEAD_SUBMIT_URL=https://example.com/api/integrations/site/leads

# Только для npm run dev: ключ подставляет Vite-прокси (без префикса VITE_ — не в JS-бандле).
# TIPA_SITE_API_KEY=

# Опционально: воронка и источник в CRM (UUID из админки)
# VITE_TIPA_FUNNEL_ID=
# VITE_TIPA_SOURCE_ID=
