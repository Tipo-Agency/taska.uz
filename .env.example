# Скопируйте в .env.local (не коммить секреты).

# POST тело — JSON как в create_deal (camelCase). По умолчанию без переменной:
#   https://tipa.taska.uz/api/deals
# Переопределите, если API на другом хосте:
# VITE_LEAD_SUBMIT_URL=https://tipa.taska.uz/api/deals

# Опционально: привязка к воронке в CRM
# VITE_TIPA_FUNNEL_ID=

# Уведомление в Telegram (опционально)
# VITE_TELEGRAM_BOT_TOKEN=
# VITE_TELEGRAM_CHAT_ID=
